<div class="sc-ma-placement sc-ma-teleport-destination">
  <div class="sc-ma-placement-summary">
    <span>{{ localize "SCMOREACTIVITIES.Activities.ScTeleport.App.Destination.Targets" }}: {{ targetCount }}</span>
    <span>{{ localize "SCMOREACTIVITIES.Activities.ScTeleport.App.Destination.Range" }}: {{ teleportDistance }}</span>
  </div>

  <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.ScTeleport.App.Destination.Hint" }}</p>

  <button type="button" class="sc-ma-teleport-cancel">
    <i class="fas fa-times"></i>
    {{ localize "SCMOREACTIVITIES.Actions.Cancel" }}
  </button>
</div>
