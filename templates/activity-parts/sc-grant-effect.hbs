<section class="tab activity-{{ tab.id }} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  {{#if appliedEffects}}{{> "systems/dnd5e/templates/activity/parts/activity-effects.hbs" }}{{/if}}

  <fieldset>
    <legend>{{ localize "SCMOREACTIVITIES.Activities.ScGrant.Sections.Configuration" }}</legend>

    <div class="form-group stacked">
      <label>{{ localize "SCMOREACTIVITIES.Activities.ScGrant.Fields.AddItem.Label" }}</label>
      <div class="form-fields sc-ma-grant-add-row">
        <input type="text" data-grant-uuid-input placeholder="{{ localize "SCMOREACTIVITIES.Activities.ScGrant.Fields.AddItem.Placeholder" }}">
        <button type="button" class="button icon" data-action="add-grant">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.ScGrant.Fields.AddItem.Hint" }}</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>{{ localize "SCMOREACTIVITIES.Activities.ScGrant.Sections.Items" }}</legend>

    {{#if grants.length}}
      <div class="sc-ma-grant-list">
        {{#each grants}}
          <div class="sc-ma-grant-row {{#if this.missing}}is-missing{{/if}}">
            <div class="sc-ma-grant-item">
              <img src="{{ this.img }}" alt="{{ this.name }}">
              <div class="sc-ma-grant-meta">
                <div class="sc-ma-grant-name">{{ this.name }}</div>
                <div class="sc-ma-grant-uuid">{{ this.uuid }}</div>
              </div>
            </div>

            <div class="sc-ma-grant-controls">
              <input type="hidden" name="grants.{{ this.index }}.uuid" value="{{ this.uuid }}">
              <label>
                {{ localize "SCMOREACTIVITIES.Activities.ScGrant.Fields.Quantity.Label" }}
                <input
                  type="number"
                  name="grants.{{ this.index }}.quantity"
                  min="1"
                  step="1"
                  value="{{ this.quantity }}"
                  data-grant-quantity
                  data-index="{{ this.index }}"
                >
              </label>
              <button type="button" class="button icon" data-action="remove-grant" data-index="{{ this.index }}">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.ScGrant.Fields.Items.Empty" }}</p>
    {{/if}}
  </fieldset>
</section>
