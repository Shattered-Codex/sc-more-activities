<section class="tab activity-{{ tab.id }} {{ tab.cssClass }}" data-tab="{{ tab.id }}" data-group="{{ tab.group }}">
  {{#if appliedEffects}}{{> "systems/dnd5e/templates/activity/parts/activity-effects.hbs" }}{{/if}}

  <fieldset>
    <legend>{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Sections.Configuration" }}</legend>

    <div class="form-group">
      <label>{{ localize "SCMOREACTIVITIES.Activities.Canvas.Fields.TargetSource.Label" }}</label>
      <div class="form-fields">
        <select name="movement.targetSource">
          {{ selectOptions targetSourceOptions selected=movement.targetSource valueAttr="value" labelAttr="label" }}
        </select>
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.Canvas.Fields.TargetSource.Hint" }}</p>
    </div>

    <div class="form-group">
      <label>{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Fields.Type.Label" }}</label>
      <div class="form-fields">
        <select name="movement.type">
          {{ selectOptions movementTypeOptions selected=movement.type valueAttr="value" labelAttr="label" }}
        </select>
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Fields.Type.Hint" }}</p>
    </div>

    <div class="form-group">
      <label>{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Fields.Distance.Label" }}</label>
      <div class="form-fields">
        <input type="number" name="movement.distance" value="{{ movement.distance }}" min="0" step="1">
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Fields.Distance.Hint" }}</p>
    </div>

    <div class="form-group">
      <label>{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Fields.MaxRange.Label" }}</label>
      <div class="form-fields">
        <input type="number" name="movement.maxRange" value="{{ movement.maxRange }}" min="0" step="1">
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.ScMovement.Fields.MaxRange.Hint" }}</p>
    </div>

    <div class="form-group">
      <label>{{ localize "SCMOREACTIVITIES.Activities.Canvas.Fields.MaxTargets.Label" }}</label>
      <div class="form-fields">
        <input type="number" name="movement.maxTargets" value="{{ movement.maxTargets }}" min="1" step="1">
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.Canvas.Fields.MaxTargets.Hint" }}</p>
    </div>

    <div class="form-group">
      <label>{{ localize "SCMOREACTIVITIES.Activities.Canvas.Fields.SnapToGrid.Label" }}</label>
      <div class="form-fields">
        <input type="checkbox" name="movement.snapToGrid" {{#if movement.snapToGrid}}checked{{/if}}>
      </div>
      <p class="hint">{{ localize "SCMOREACTIVITIES.Activities.Canvas.Fields.SnapToGrid.Hint" }}</p>
    </div>
  </fieldset>
</section>
